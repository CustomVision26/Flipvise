# Database (Neon PostgreSQL)
DATABASE_URL=

# Public site URL (used in team invitation links). In production set to your domain.
# Production (Render): https://flipvise-sjgw.onrender.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile (Capacitor) — live host the native app navigates to / syncs against.
# CAP_LIVE_HOST is read by capacitor.config.ts; VITE_LIVE_URL by the offline study build
# (npm run mobile:build). Both default to https://flipvise-sjgw.onrender.com if unset.
CAP_LIVE_HOST=https://flipvise-sjgw.onrender.com
VITE_LIVE_URL=https://flipvise-sjgw.onrender.com
#
# Android emulator + local Next dev (10.0.2.2 is the emulator alias for your PC):
#   1. Run `npm run dev` (port 3000)
#   2. Set the two lines below, then `npm run mobile:sync` and reinstall the app
# CAP_LIVE_HOST=10.0.2.2:3000
# VITE_LIVE_URL=http://10.0.2.2:3000
# CAP_ANDROID_DEV_HOST=10.0.2.2:3000

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Opt out of Clerk SDK telemetry (removes dev-server notice; optional in production too).
NEXT_PUBLIC_CLERK_TELEMETRY_DISABLED=1
CLERK_TELEMETRY_DISABLED=1
#
# Clerk Dashboard → Configure (for web + Capacitor mobile):
#   Home URL:              https://flipvise-sjgw.onrender.com
#   Allowed redirect URLs: https://flipvise-sjgw.onrender.com/*
#                          http://localhost:3000/*          (local dev)
#   Authorized JS origins: https://flipvise-sjgw.onrender.com
#                          http://localhost:3000            (local dev)
# Sign-in runs on the live site inside the app WebView — capacitor://localhost is NOT
# needed for Clerk. Offline sync uses device tokens (/api/sync), not Clerk cookies.

# Native push notifications (Capacitor iOS/Android via Firebase Cloud Messaging)
# Firebase Console → Project settings → Service accounts → Generate new private key.
# Paste the full JSON as a single-line string in Render (or use a secrets manager).
FIREBASE_SERVICE_ACCOUNT_JSON=
# Live web deploy version — bump on each Render deploy to prompt native WebView refresh.
# Defaults to RENDER_GIT_COMMIT when unset.
NATIVE_DEPLOY_VERSION=
# Native store semver (match android/app/build.gradle versionName and iOS CFBundleShortVersionString).
NATIVE_ANDROID_MIN_VERSION=1.0.0
NATIVE_ANDROID_LATEST_VERSION=1.0.3
NATIVE_IOS_MIN_VERSION=1.0.0
NATIVE_IOS_LATEST_VERSION=1.0.3
NATIVE_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.flipvise.app
NATIVE_IOS_STORE_URL=https://apps.apple.com/app/flipvise/id0000000000

# Stripe Billing
# 1) Dashboard → Developers → API keys: copy test (sk_test_ / pk_test_) or live keys; both must be same mode.
# 2) Products: create recurring Prices (month + year) for Pro, Pro Plus, and each team tier. Copy each Price ID (price_…) into the vars below.
# 3) Webhooks: endpoint https://<your-host>/api/webhooks/stripe — events at minimum:
#    checkout.session.completed, customer.subscription.created, customer.subscription.updated,
#    customer.subscription.deleted, customer.subscription.trial_will_end, invoice.payment_failed,
#    invoice.payment_succeeded, invoice.paid, invoice.finalized
#    Local dev: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` and paste the signing secret (whsec_…) here.
# 4) Stripe Dashboard → Settings → Customer portal: enable so “Manage billing” works.
# 5) Tax (optional in test): Checkout uses automatic tax; configure in Stripe if you hit tax errors.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PRO_PLUS_PRICE_ID=
STRIPE_PRO_PLUS_YEARLY_PRICE_ID=
# Team tiers — canonical env names (preferred). Code falls back to legacy STRIPE_PRO_TEAM_* if unset.
STRIPE_PRO_PLUS_TEAM_BASIC_PRICE_ID=
STRIPE_PRO_PLUS_TEAM_BASIC_YEARLY_PRICE_ID=
STRIPE_PRO_PLUS_TEAM_GOLD_PRICE_ID=
STRIPE_PRO_PLUS_TEAM_GOLD_YEARLY_PRICE_ID=
STRIPE_PRO_PLUS_PLATINUM_PLAN_PRICE_ID=
STRIPE_PRO_PLUS_PLATINUM_PLAN_YEARLY_PRICE_ID=
STRIPE_PRO_PLUS_ENTERPRISE_PRICE_ID=
STRIPE_PRO_PLUS_ENTERPRISE_YEARLY_PRICE_ID=
# Education tiers
STRIPE_EDUCATION_PLUS_PRICE_ID=
STRIPE_EDUCATION_YEARLY_PLUS_PRICE_ID=
STRIPE_EDUCATION_GOLD_PRICE_ID=
STRIPE_EDUCATION_YEARLY_GOLD_PRICE_ID=
STRIPE_EDUCATION_ENTERPRISE_PRICE_ID=
STRIPE_EDUCATION_YEARLY_ENTERPRISE_PRICE_ID=
# Legacy aliases (optional — used when the STRIPE_PRO_PLUS_TEAM_* vars above are not set)
STRIPE_PRO_TEAM_BASIC_PRICE_ID=
STRIPE_PRO_TEAM_BASIC_YEARLY_PRICE_ID=
STRIPE_PRO_TEAM_GOLD_PRICE_ID=
STRIPE_PRO_TEAM_GOLD_YEARLY_PRICE_ID=
STRIPE_PRO_PLATINUM_PLAN_PRICE_ID=
STRIPE_PRO_PLATINUM_PLAN_YEARLY_PRICE_ID=
STRIPE_PRO_ENTERPRISE_PRICE_ID=
STRIPE_PRO_ENTERPRISE_YEARLY_PRICE_ID=

# Platform owner(s): comma-separated Clerk user IDs. These users get `publicMetadata.role = superadmin`
# on `/admin` load, can grant/revoke co-admins, and can ban co-admin accounts. Set in production.
PLATFORM_SUPERADMIN_USER_IDS=user_3CL3VVo19GBtTo00XJvygYddloT
# Optional: post sign-in/up destination when Clerk has no redirect_url (helps App Router + modal auth).
# App Sign In/Up buttons use /auth/continue → /dashboard?userid=…&plan=…; align env with that if you set these.
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/continue
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth/continue

# Loops (transactional email)
# Get your API key at https://app.loops.so/settings?page=api
LOOPS_API_KEY=
# Quiz-result — TAKER: personal decks; team-deck saves where taker is workspace owner OR any non–team-workspace save; one send to taker.
LOOPS_QUIZ_RESULT_TAKER_TRANSACTIONAL_ID=
# Quiz-result — OWNER: only team-workspace save when taker is invited member/admin (two sends: member + owner).
LOOPS_QUIZ_RESULT_OWNER_TRANSACTIONAL_ID=
# Quiz-result emails do not attach a PDF unless you opt in (requires Loops API attachments on your plan).
# LOOPS_QUIZ_RESULT_ATTACH_PDF=true

# Team workspace invitation email — transactional template must define these data variables (case-sensitive):
# subjectLine, acceptInvitationUrl (primary accept link /invite/team/{token}), dashboardInboxUrl (/dashboard/inbox),
# inviteeEmail, inviteeName, workspaceName, roleLabel, inviterName, expiresInDays
LOOPS_TEAM_INVITATION_TRANSACTIONAL_ID=

# Marketing affiliate invite (Loops) — transactional only when invitee email has NO Clerk match at invite time:
# signed-up users receive dashboard inbox reminder only (no send from this branch).
# Data variables if used (case-sensitive):
# subjectLine, acceptAffiliateUrl, dashboardInboxUrl, inviteeEmail, affiliateName,
# planAssigned, planLabel, affiliateEndsAt, inviteExpiresInDays, inviteExpiresAt, inviterName
LOOPS_AFFILIATE_INVITATION_TRANSACTIONAL_ID=
# Active affiliate plan/end edits: unread inbox confirmation only (no transactional send from `updateAffiliateAction`).
# Historical / optional fork: transactional payload keys documented on `loopsSendAffiliateArrangementUpdateEmail` in loops.ts.
LOOPS_AFFILIATE_ARRANGEMENT_UPDATE_TRANSACTIONAL_ID=

# Admin ban / unban — sent to the user's primary email after `toggleUserBanAction`.
# Use separate published transactional templates (same data variables on both; see loops.ts).
# Data variables (case-sensitive): subjectLine, accountState, statusHeadLine and/or statusHeadline, statusMessage,
# userName, userEmail, homeUrl, signInUrl, actionAt
LOOPS_ACCOUNT_BANNED_TRANSACTIONAL_ID=
LOOPS_ACCOUNT_UNBANNED_TRANSACTIONAL_ID=
# Billing trial / payment grace notices use the dashboard inbox (`billing_notice_inbox_messages`), not Loops.
# Optional legacy fallback if both ban actions share one template:
# LOOPS_ACCOUNT_STATUS_TRANSACTIONAL_ID=
# Admin promo inbox: general broadcast can fan out to all Clerk users; affiliate code broadcast is affiliate-only (`affiliate_broadcast_inbox_messages`). No Loops env vars.
# Days until an affiliate invite link stops accepting (default 14; integer 1–365).
# AFFILIATE_INVITE_EXPIRY_DAYS=14

# OpenAI API (for AI flashcard generation)
OPENAI_API_KEY=

# AWS S3 Configuration (for image uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# AWS CloudFront CDN (optional - improves image delivery performance)
# If not set, images will be served directly from S3
AWS_CLOUDFRONT_URL=
