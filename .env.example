# Database (Neon PostgreSQL)
DATABASE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# OpenAI API (for AI flashcard generation)
OPENAI_API_KEY=

# AWS S3 Configuration (for image uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# AWS CloudFront CDN (optional - improves image delivery performance)
# If not set, images will be served directly from S3
AWS_CLOUDFRONT_URL=
