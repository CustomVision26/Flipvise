    "@aws-sdk/lib-storage": "^3.1030.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.7",
    "@clerk/themes": "^2.4.57",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tailwindcss/postcss": "^4",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.149",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jspdf": "^4.2.1",
    "loops": "^6.3.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.6.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "patch-package": "^8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
