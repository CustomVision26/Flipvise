    "db:studio:local": "drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:prod": "drizzle-kit studio --config=drizzle.config.prod.mjs",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:migrate:local": "drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:migrate:prod": "drizzle-kit migrate --config=drizzle.config.prod.mjs",
    "db:migrate-cloudfront": "tsx scripts/migrate-cloudfront-to-s3.ts",
    "db:verify-s3": "tsx scripts/verify-s3-setup.ts",
    "stripe:cancel-duplicate-subs": "tsx scripts/cancel-duplicate-stripe-subs.ts",
    "stripe:reconcile-duplicate-subs": "tsx scripts/reconcile-duplicate-stripe-subs.ts",
    "docs:validate": "tsx scripts/documentation-sync.ts validate",
