    "db:ensure-deck-gradient-column": "tsx scripts/ensure-deck-gradient-column.ts",
    "db:ensure-team-invite-revoked-enum": "tsx scripts/ensure-team-invitation-revoked-enum.ts",
    "db:ensure-team-workspace-events": "tsx scripts/ensure-team-workspace-events.ts",
    "db:ensure-team-member-audit-columns": "tsx scripts/ensure-team-member-audit-columns.ts",
    "db:ensure-owner-quiz-enforce-column": "tsx scripts/ensure-owner-quiz-enforce-column.ts",
    "db:ensure-quiz-security-tables": "tsx scripts/ensure-quiz-security-tables.ts",
    "db:ensure-quiz-schedule-columns": "tsx scripts/ensure-quiz-schedule-columns.ts",
    "db:ensure-quiz-question-formats": "tsx scripts/ensure-quiz-question-formats.ts",
    "db:ensure-quiz-format-assignments": "tsx scripts/ensure-quiz-format-assignments.ts",
