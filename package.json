    "db:migrate:prod": "drizzle-kit migrate --config=drizzle.config.prod.mjs",
    "db:migrate-cloudfront": "tsx scripts/migrate-cloudfront-to-s3.ts",
    "db:verify-s3": "tsx scripts/verify-s3-setup.ts",
    "stripe:cancel-duplicate-subs": "tsx scripts/cancel-duplicate-stripe-subs.ts",
    "stripe:reconcile-duplicate-subs": "tsx scripts/reconcile-duplicate-subs.ts",
    "stripe:verify-env": "tsx scripts/verify-stripe-price-env.ts",
    "docs:validate": "tsx scripts/documentation-sync.ts validate",
    "docs:validate:ci": "tsx scripts/documentation-sync.ts validate-ci",
    "docs:baseline": "tsx scripts/documentation-sync.ts baseline",
    "docs:stale": "tsx scripts/documentation-sync.ts stale",
    "prebuild": "npm run docs:validate:ci",
    "lint": "eslint",
    "logo:transparent": "node scripts/remove-logo-background.cjs",
    "pwa:favicons": "node scripts/generate-pwa-favicons.mjs",
    "cap": "cap",
    "mobile:build": "vite build -c mobile/vite.config.ts",
    "mobile:build:prod": "cross-env VITE_LIVE_URL=https://flipvise-sjgw.onrender.com vite build -c mobile/vite.config.ts",
    "mobile:verify": "node scripts/verify-mobile-web-bundle.mjs",
    "mobile:build:dev": "cross-env VITE_LIVE_URL=http://127.0.0.1:3000 vite build -c mobile/vite.config.ts",
    "mobile:sync:dev": "cross-env CAP_ANDROID_DEV_HOST=http://127.0.0.1:3000 VITE_LIVE_URL=http://127.0.0.1:3000 npm run mobile:build:dev && cross-env CAP_ANDROID_DEV_HOST=http://127.0.0.1:3000 npx cap sync",
    "mobile:adb-reverse": "adb reverse tcp:3000 tcp:3000",
    "mobile:assets": "capacitor-assets generate --android --iconBackgroundColor \"#0f172a\" --splashBackgroundColor \"#0f172a\"",
    "mobile:assets:ios": "capacitor-assets generate --ios --iconBackgroundColor \"#0f172a\" --splashBackgroundColor \"#0f172a\"",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "mobile:sync": "npm run mobile:build && cap sync && npm run mobile:verify && npm run mobile:assets",
    "mobile:sync:prod": "cross-env CAP_LIVE_HOST=https://flipvise-sjgw.onrender.com VITE_LIVE_URL=https://flipvise-sjgw.onrender.com npm run mobile:build:prod && cap sync && npm run mobile:verify && npm run mobile:assets",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios"
