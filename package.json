    "docs:baseline": "tsx scripts/documentation-sync.ts baseline",
    "docs:stale": "tsx scripts/documentation-sync.ts stale",
    "prebuild": "npm run docs:validate:ci",
    "lint": "eslint",
    "logo:transparent": "node scripts/remove-logo-background.cjs"
