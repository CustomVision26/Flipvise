    "db:generate:local": "drizzle-kit generate --config=drizzle.config.local.ts",
    "db:generate:prod": "drizzle-kit generate --config=drizzle.config.local.ts",
    "db:studio:local": "drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:prod": "drizzle-kit studio --config=drizzle.config.prod.mjs",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.local.ts",
