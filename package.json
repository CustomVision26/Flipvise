{
  "name": "flipvise",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=10240 next dev --webpack",
    "build": "next build",
    "start": "next start -p $PORT",
    "db:push:local": "drizzle-kit push --config=drizzle.config.local.ts",
    "db:ensure-admin-audit-tables": "tsx scripts/ensure-admin-audit-tables.ts",
