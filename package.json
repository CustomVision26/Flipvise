    "db:ensure-affiliate-promo-columns": "tsx scripts/ensure-affiliate-promo-columns.ts",
    "db:ensure-affiliate-pending-arrangement-columns": "tsx scripts/ensure-affiliate-pending-arrangement-columns.ts",
    "db:ensure-affiliate-broadcast-inbox": "tsx scripts/ensure-affiliate-broadcast-inbox-table.ts",
    "db:ensure-subscription-checkout-inbox": "tsx scripts/ensure-subscription-checkout-inbox-table.ts",
