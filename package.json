{
  "name": "flipvise",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "postinstall": "patch-package && node scripts/patch-capacitor-android-bridge.js",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=10240 next dev --turbopack",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "dev:webpack": "cross-env NODE_OPTIONS=--max-old-space-size=10240 next dev --webpack",
    "dev:webpack:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev:webpack",
    "build": "next build",
    "start": "next start -p $PORT",
    "db:push:local": "drizzle-kit push --config=drizzle.config.local.ts",
    "db:ensure-admin-audit-tables": "tsx scripts/ensure-admin-audit-tables.ts",
    "db:ensure-deck-cover-column": "tsx scripts/ensure-deck-cover-column.ts",
    "db:ensure-deck-gradient-column": "tsx scripts/ensure-deck-gradient-column.ts",
    "db:ensure-team-invite-revoked-enum": "tsx scripts/ensure-team-invitation-revoked-enum.ts",
