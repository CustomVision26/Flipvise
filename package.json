{
  "name": "flipvise",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=10240 next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "db:push:local": "drizzle-kit push --config=drizzle.config.local.ts",
    "db:ensure-deck-cover-column": "tsx scripts/ensure-deck-cover-column.ts",
    "db:ensure-deck-gradient-column": "tsx scripts/ensure-deck-gradient-column.ts",
    "db:ensure-team-invite-revoked-enum": "tsx scripts/ensure-team-invitation-revoked-enum.ts",
    "db:ensure-team-workspace-events": "tsx scripts/ensure-team-workspace-events.ts",
    "db:ensure-team-member-audit-columns": "tsx scripts/ensure-team-member-audit-columns.ts",
    "db:ensure-stripe-subscriptions": "tsx scripts/ensure-stripe-subscriptions.ts",
    "db:push:prod": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate:local": "drizzle-kit generate --config=drizzle.config.local.ts",
    "db:generate:prod": "drizzle-kit generate --config=drizzle.config.ts",
    "db:studio:local": "drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:prod": "drizzle-kit studio --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:local": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:prod": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate-cloudfront": "tsx scripts/migrate-cloudfront-to-s3.ts",
    "db:verify-s3": "tsx scripts/verify-s3-setup.ts",
    "lint": "eslint",
    "logo:transparent": "node scripts/remove-logo-background.cjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/lib-storage": "^3.1030.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.7",
    "@clerk/themes": "^2.4.57",
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/postcss": "^4",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.149",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jspdf": "^4.2.1",
    "loops": "^6.3.0",
    "lucide-react": "^1.6.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "patch-package": "^8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
