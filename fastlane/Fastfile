default_platform(:ios)

APP_IDENTIFIER = "com.flipvise.ios"
XCODE_PROJECT = "ios/App/App.xcodeproj"
XCODE_SCHEME = "App"

platform :ios do
  # Builds the iOS app and uploads it to TestFlight.
  #
  # Signing uses App Store Connect API key authentication combined with Xcode
  # automatic provisioning (`-allowProvisioningUpdates`), so no certificates or
  # provisioning profiles need to be committed or stored as separate secrets.
  #
  # Required environment variables (set as GitHub Actions secrets):
  #   ASC_KEY_ID       - App Store Connect API key ID
  #   ASC_ISSUER_ID    - App Store Connect API issuer ID
  #   ASC_KEY_CONTENT  - base64-encoded contents of the .p8 key file
  #   APPLE_TEAM_ID    - 10-character Apple Developer Team ID
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      # The workflow materializes the .p8 to a file (handles base64 or raw PEM
      # secrets) and exports its path — avoids fastlane's null-byte base64 bug.
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false,
    )

    team_id = ENV.fetch("APPLE_TEAM_ID")

    # Derive the next build number from TestFlight so uploads never collide.
    # Injected directly at build time (CURRENT_PROJECT_VERSION) to avoid agvtool,
    # since the project does not use apple-generic versioning.
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    )
    next_build = latest_build + 1

    # Pass the App Store Connect API key directly to xcodebuild so that
    # `-allowProvisioningUpdates` can register the App ID and create the signing
    # certificate + provisioning profile automatically (cloud signing).
    xcodebuild_args = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath", ENV.fetch("ASC_KEY_PATH"),
      "-authenticationKeyID", ENV.fetch("ASC_KEY_ID"),
      "-authenticationKeyIssuerID", ENV.fetch("ASC_ISSUER_ID"),
      "DEVELOPMENT_TEAM=#{team_id}",
      "CURRENT_PROJECT_VERSION=#{next_build}",
    ].join(" ")

    build_app(
      project: XCODE_PROJECT,
      scheme: XCODE_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: xcodebuild_args,
      export_options: {
        signingStyle: "automatic",
        teamID: team_id,
      },
      output_directory: "build",
      output_name: "Flipvise.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
    )
  end
end
