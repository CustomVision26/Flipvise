default_platform(:ios)

APP_IDENTIFIER = "com.flipvise.ios"
XCODE_PROJECT = "ios/App/App.xcodeproj"
XCODE_SCHEME = "App"

platform :ios do
  # Builds the iOS app and uploads it to TestFlight.
  #
  # Signing uses fastlane `match` (App Store / distribution). match stores the
  # distribution certificate + private key + provisioning profile ENCRYPTED in a
  # dedicated git branch, so every CI run reuses the same certificate instead of
  # generating a new one (which would exhaust the account's certificate limit).
  # Automatic signing is intentionally NOT used: `xcodebuild archive` with
  # automatic signing tries to create a *Development* profile, which requires a
  # registered device and therefore cannot work on a headless CI runner.
  #
  # Required environment variables (set as GitHub Actions secrets / by the workflow):
  #   ASC_KEY_ID                     - App Store Connect API key ID
  #   ASC_ISSUER_ID                  - App Store Connect API issuer ID
  #   ASC_KEY_PATH                   - path to the .p8 file (materialized by the workflow)
  #   APPLE_TEAM_ID                  - 10-character Apple Developer Team ID
  #   MATCH_PASSWORD                 - passphrase used to encrypt the match storage
  #   MATCH_GIT_URL                  - git URL of the repo holding the encrypted certs
  #   MATCH_GIT_BASIC_AUTHORIZATION  - base64 "x-access-token:<token>" for git auth
  # One-off maintenance lane: revokes all Apple Distribution certificates and
  # clears the match storage so a fresh certificate can be generated. Use only
  # when match reports the distribution certificate limit has been reached.
  desc "Revoke distribution certs and reset match storage"
  lane :nuke_certs do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false,
    )

    match_nuke(
      type: "appstore",
      api_key: api_key,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_branch: ENV.fetch("MATCH_GIT_BRANCH", "match-certificates"),
      skip_confirmation: true,
    )
  end

  desc "Build and upload a new build to TestFlight"
  lane :beta do
    # Create/unlock a temporary keychain for the imported signing certificate.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false,
    )

    team_id = ENV.fetch("APPLE_TEAM_ID")

    # Derive the next build number from TestFlight so uploads never collide.
    # Injected at build time (CURRENT_PROJECT_VERSION) to avoid agvtool, since the
    # project does not use apple-generic versioning.
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    )
    next_build = latest_build + 1

    # Fetch (or create on first run) the App Store distribution certificate and
    # provisioning profile, importing them into the CI keychain.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      team_id: team_id,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_branch: ENV.fetch("MATCH_GIT_BRANCH", "match-certificates"),
      readonly: false,
    )
    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][APP_IDENTIFIER]

    # Switch the Release config to manual signing with the fetched profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODE_PROJECT,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"],
      build_configurations: ["Release"],
    )

    build_app(
      project: XCODE_PROJECT,
      scheme: XCODE_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      export_options: {
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name,
        },
      },
      output_directory: "build",
      output_name: "Flipvise.ipa",
      clean: true,
    )

    # Build the TestFlight "What to Test" notes. A changelog provided by the
    # workflow (TESTFLIGHT_CHANGELOG) takes precedence; otherwise fall back to
    # the latest commit message. Attaching a changelog requires waiting for the
    # build to finish processing, so skip_waiting_for_build_processing is false.
    changelog = ENV["TESTFLIGHT_CHANGELOG"].to_s.strip
    if changelog.empty?
      changelog = sh("git", "log", "-1", "--pretty=%B", log: false).strip
    end

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      changelog: changelog,
      distribute_external: false,
      skip_waiting_for_build_processing: false,
    )
  end
end

platform :android do
  # One-off helper: creates a Firebase App Distribution tester group with the
  # alias "testers". Add testers to it in the Firebase console (or via the
  # firebase_app_distribution_add_testers action) afterwards.
  desc "Create a Firebase App Distribution tester group (alias: testers)"
  lane :create_group do
    project_number = ENV.fetch("FIREBASE_ANDROID_APP_ID").split(":")[1]
    firebase_app_distribution_create_group(
      project_number: project_number,
      alias: "testers",
      display_name: "Testers",
      service_credentials_file: ENV.fetch("FIREBASE_SERVICE_CREDENTIALS_FILE"),
    )
  end

  # Builds a release-signed APK and distributes it to testers via Firebase App
  # Distribution. The release keystore is provided by the workflow (decoded from
  # a base64 secret), so the signing key is stable across runs and testers get
  # seamless in-place updates. The same signed artifact is Play-Store ready.
  #
  # Required environment variables (set as GitHub Actions secrets / by the workflow):
  #   FIREBASE_ANDROID_APP_ID           - Firebase Android app id (1:NNNN:android:XXXX)
  #   FIREBASE_SERVICE_CREDENTIALS_FILE - path to the service account JSON (written by the workflow)
  #   FIREBASE_TESTER_GROUPS            - optional comma-separated Firebase tester group aliases
  #   ANDROID_KEYSTORE_PATH             - path to the decoded release keystore
  #   ANDROID_KEYSTORE_PASSWORD         - keystore password
  #   ANDROID_KEY_ALIAS                 - signing key alias
  #   ANDROID_KEY_PASSWORD              - signing key password
  desc "Build a release-signed APK and distribute it via Firebase App Distribution"
  lane :firebase do
    gradle(
      project_dir: "android",
      task: "assemble",
      build_type: "Release",
    )

    # Release notes default to the latest commit message unless provided.
    release_notes = ENV["FIREBASE_RELEASE_NOTES"].to_s.strip
    if release_notes.empty?
      release_notes = sh("git", "log", "-1", "--pretty=%B", log: false).strip
    end

    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH] ||
               "android/app/build/outputs/apk/release/app-release.apk"

    options = {
      app: ENV.fetch("FIREBASE_ANDROID_APP_ID"),
      service_credentials_file: ENV.fetch("FIREBASE_SERVICE_CREDENTIALS_FILE"),
      android_artifact_type: "APK",
      android_artifact_path: apk_path,
      release_notes: release_notes,
    }

    groups = ENV["FIREBASE_TESTER_GROUPS"].to_s.strip
    options[:groups] = groups unless groups.empty?

    firebase_app_distribution(options)
  end
end
