# ============================================
# PRODUCTION ENVIRONMENT TEMPLATE
# ============================================
# Copy this file and fill in your production values
# Set these as environment variables in Render

# === DATABASE (Production Neon) ===
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST/YOUR_DB?sslmode=require

# === CLERK (Live Keys) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_live_YOUR_PRODUCTION_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET

# === STRIPE (Live Keys) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_PRODUCTION_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRODUCTION_PRO_PRICE_ID
STRIPE_PRO_YEARLY_PRICE_ID=price_YOUR_PRODUCTION_PRO_YEARLY_PRICE_ID
STRIPE_PRO_TEAM_BASIC_PRICE_ID=price_YOUR_PRODUCTION_PRO_TEAM_BASIC_PRICE_ID
STRIPE_PRO_TEAM_BASIC_YEARLY_PRICE_ID=price_YOUR_PRODUCTION_PRO_TEAM_BASIC_YEARLY_PRICE_ID
STRIPE_PRO_TEAM_GOLD_PRICE_ID=price_YOUR_PRODUCTION_PRO_TEAM_GOLD_PRICE_ID
STRIPE_PRO_TEAM_GOLD_YEARLY_PRICE_ID=price_YOUR_PRODUCTION_PRO_TEAM_GOLD_YEARLY_PRICE_ID
STRIPE_PRO_PLATINUM_PLAN_PRICE_ID=price_YOUR_PRODUCTION_PRO_PLATINUM_PLAN_PRICE_ID
STRIPE_PRO_PLATINUM_PLAN_YEARLY_PRICE_ID=price_YOUR_PRODUCTION_PRO_PLATINUM_PLAN_YEARLY_PRICE_ID
STRIPE_PRO_ENTERPRISE_PRICE_ID=price_YOUR_PRODUCTION_PRO_ENTERPRISE_PRICE_ID
STRIPE_PRO_ENTERPRISE_YEARLY_PRICE_ID=price_YOUR_PRODUCTION_PRO_ENTERPRISE_YEARLY_PRICE_ID

# === OPENAI ===
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY

# === AWS S3 (Production Bucket) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME

# === VERCEL BLOB (Production) ===
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_YOUR_PRODUCTION_TOKEN
